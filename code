import random

def guessing_game():
    secret_number = random.randint(1, 100)
    max_attempts = 5

    print("Ласкаво просимо до гри на здогадвання числа!")
    print(f"Загадано число від 1 до 100. У вас є {max_attempts} спроб вгадати його.\n")

    for attempt in range(1, max_attempts + 1):
        print(f"Спроба {attempt}/{max_attempts}")

        #Перевірка на те щоб юзер ввів правильне число
        while True:
            user_input = input("Введіть ваше число: ").strip()
            if user_input.isdigit():
                guess = int(user_input)
                if 1 <= guess <= 100:
                    break
                else:
                    print("Будь ласка, введіть число між 1 та 100.")
            else:
                print("Невірний ввід. Будь ласка, введіть ціле число.")

        if guess == secret_number:
            print(f"\nВітаємо! Ви вгадали правильне число за {attempt} спроби!")
            return
        elif guess < secret_number:
            print("Занадто мало!\n")
        else:
            print("Занадто багато!\n")

        # Залишкові спроби
        remaining = max_attempts - attempt
        if remaining > 0:
            print(f"   {remaining} спроби залишилося.\n")

    # Всі спробі неправильні
    print(f"\n😢  Ви вичерпали всі спроби.Правильне число було {secret_number}.")

guessing_game()
